<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simulasi Sewa Lahan Komersil — Kota Bandung</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f12;
    --surface: #14171c;
    --surface2: #1c2028;
    --surface3: #232830;
    --border: rgba(255,255,255,0.07);
    --border-hover: rgba(255,255,255,0.14);
    --text: #e8e6e0;
    --muted: #7a7870;
    --subtle: #3a3d45;
    --accent: #c8f04a;
    --accent-dim: rgba(200,240,74,0.12);
    --accent-glow: rgba(200,240,74,0.25);
    --blue: #4a9eff;
    --blue-dim: rgba(74,158,255,0.12);
    --red: #ff6b6b;
    --red-dim: rgba(255,107,107,0.12);
    --amber: #ffb547;
    --amber-dim: rgba(255,181,71,0.12);
    --green: #4ade80;
    --green-dim: rgba(74,222,128,0.12);
    --font-display: 'DM Serif Display', serif;
    --font-body: 'Outfit', sans-serif;
    --font-mono: 'DM Mono', monospace;
    --radius: 12px;
    --radius-sm: 8px;
    --radius-lg: 18px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* Noise texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: .5;
  }

  .page {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  /* Header */
  .header {
    margin-bottom: 48px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .header-left {}
  .label-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-dim);
    border: 1px solid rgba(200,240,74,0.2);
    color: var(--accent);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 99px;
    margin-bottom: 16px;
  }
  .label-pill::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text);
    letter-spacing: -.01em;
  }
  h1 em { color: var(--accent); font-style: italic; }
  .subtitle {
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
    font-weight: 300;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 8px 14px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    align-self: flex-end;
  }

  /* Layout */
  .main-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 20px;
    align-items: start;
  }
  @media(max-width:900px){ .main-grid { grid-template-columns: 1fr; } }

  /* Control Panel */
  .control-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    position: sticky;
    top: 24px;
  }
  .panel-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .panel-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .control-group {
    margin-bottom: 28px;
  }
  .control-group:last-child { margin-bottom: 0; }

  .ctrl-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 10px;
  }
  .ctrl-label {
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
  }
  .ctrl-value {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 3px 10px;
    border-radius: 6px;
    min-width: 110px;
    text-align: right;
  }

  /* Custom Slider */
  input[type=range] {
    -webkit-appearance: none;
    width: 100%;
    height: 2px;
    background: var(--subtle);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    margin-bottom: 8px;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-dim);
    cursor: pointer;
    transition: box-shadow .15s;
  }
  input[type=range]:hover::-webkit-slider-thumb {
    box-shadow: 0 0 0 6px var(--accent-glow);
  }
  input[type=range]::-moz-range-thumb {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    cursor: pointer;
  }

  .slider-minmax {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--subtle);
  }

  .divider { height: 1px; background: var(--border); margin: 24px 0; }

  .quick-presets {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 20px;
  }
  .preset-btn {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 5px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
  }
  .preset-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  /* Right column */
  .results { display: flex; flex-direction: column; gap: 16px; }

  /* Metric cards */
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media(max-width:600px){ .metrics-row { grid-template-columns: 1fr 1fr; } }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    transition: border-color .2s;
  }
  .metric-card:hover { border-color: var(--border-hover); }
  .metric-card.accent-card {
    border-color: rgba(200,240,74,0.2);
    background: linear-gradient(135deg, var(--surface) 60%, rgba(200,240,74,0.04));
  }
  .mc-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .mc-value {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    line-height: 1;
    margin-bottom: 4px;
  }
  .metric-card.accent-card .mc-value { color: var(--accent); }
  .mc-sub {
    font-size: 11px;
    color: var(--muted);
  }

  /* Section cards */
  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .sc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--border);
  }
  .sc-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
  }
  .sc-body { padding: 20px 24px; }

  /* Table */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }
  .data-table thead th {
    text-align: left;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 12px 12px;
    border-bottom: 1px solid var(--border);
  }
  .data-table tbody td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text);
  }
  .data-table tbody tr:last-child td { border-bottom: none; }
  .data-table tbody tr:hover td { background: var(--surface2); }
  .data-table .total-row td {
    border-top: 1px solid var(--border-hover);
    color: var(--text);
    font-weight: 500;
    font-size: 13px;
    background: var(--surface2);
  }

  /* Badges */
  .badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 99px;
    font-family: var(--font-mono);
  }
  .badge-green { background: var(--green-dim); color: var(--green); }
  .badge-amber { background: var(--amber-dim); color: var(--amber); }
  .badge-red   { background: var(--red-dim); color: var(--red); }
  .badge-blue  { background: var(--blue-dim); color: var(--blue); }
  .badge-accent{ background: var(--accent-dim); color: var(--accent); }

  /* Chart container */
  .chart-wrap { position: relative; width: 100%; height: 240px; }

  /* Highlight boxes */
  .insight {
    display: flex;
    gap: 12px;
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    margin-bottom: 10px;
    font-size: 13px;
    line-height: 1.5;
    border: 1px solid;
  }
  .insight:last-child { margin-bottom: 0; }
  .insight-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .insight-g { background: var(--green-dim); border-color: rgba(74,222,128,.2); color: var(--green); }
  .insight-a { background: var(--amber-dim); border-color: rgba(255,181,71,.2); color: var(--amber); }
  .insight-b { background: var(--blue-dim); border-color: rgba(74,158,255,.2); color: var(--blue); }
  .insight strong { font-weight: 600; display: block; margin-bottom: 2px; }

  /* Skema comparison */
  .skema-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding: 20px 24px;
  }
  @media(max-width:600px){ .skema-grid { grid-template-columns: 1fr; } }
  .skema-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    transition: border-color .2s;
  }
  .skema-card.recommended {
    border-color: rgba(200,240,74,0.35);
    background: linear-gradient(135deg, var(--surface2), rgba(200,240,74,0.04));
  }
  .skema-label { font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; font-weight: 500; }
  .skema-amount { font-family: var(--font-mono); font-size: 17px; font-weight: 500; color: var(--text); margin-bottom: 6px; line-height: 1.2; }
  .skema-total { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-bottom: 8px; }

  /* Footer watermark */
  .footer {
    margin-top: 60px;
    text-align: center;
    font-size: 11px;
    color: var(--subtle);
    font-family: var(--font-mono);
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--subtle); border-radius: 99px; }

  /* Progress bar for beban */
  .progress-track {
    height: 4px;
    background: var(--subtle);
    border-radius: 99px;
    margin-top: 6px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width .4s ease;
  }

  .section-tag {
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <div class="label-pill">Simulasi Investasi Aktif</div>
      <h1>Kalkulator Sewa<br>Lahan <em>Komersil</em></h1>
      <p class="subtitle">Kota Bandung · Jalan Kolektor · Kontrak 10 Tahun · Bayar Per Tahun</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-end">
      <div class="last-updated" id="timestamp"></div>
      <button onclick="downloadPDF()" id="pdf-btn" style="display:flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:12px;font-weight:500;padding:10px 18px;border-radius:8px;border:1px solid rgba(200,240,74,0.4);background:rgba(200,240,74,0.1);color:#c8f04a;cursor:pointer;transition:all .15s;white-space:nowrap">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Unduh laporan PDF
      </button>
    </div>
  </div>

  <div class="main-grid">

    <!-- LEFT: Control Panel -->
    <div class="control-panel">
      <div class="panel-title">Parameter</div>

      <div class="control-group">
        <div class="ctrl-header">
          <span class="ctrl-label">Luas lahan</span>
          <span class="ctrl-value" id="v-luas">700 m²</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <input type="range" id="s-luas" min="1" max="10000" step="1" value="700" oninput="syncLuasFromSlider()" style="flex:1;margin-bottom:0">
          <input type="number" id="n-luas" min="1" max="10000" value="700" oninput="syncLuasFromInput()" style="width:72px;font-family:var(--font-mono);font-size:13px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 8px;outline:none;-moz-appearance:textfield">
        </div>
        <div class="slider-minmax"><span>1 m²</span><span>10.000 m²</span></div>
      </div>

      <div class="control-group">
        <div class="ctrl-header">
          <span class="ctrl-label">Harga sewa / m² / bulan</span>
          <span class="ctrl-value" id="v-harga">Rp 12.500</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <input type="range" id="s-harga" min="1" max="833333" step="1" value="12500" oninput="syncHargaFromSlider()" style="flex:1;margin-bottom:0">
          <input type="number" id="n-harga" min="1" max="833333" value="12500" oninput="syncHargaFromInput()" style="width:88px;font-family:var(--font-mono);font-size:13px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 8px;outline:none;-moz-appearance:textfield">
        </div>
        <div class="slider-minmax"><span>1</span><span>833.333/m²</span></div>
      </div>

      <div class="control-group">
        <div class="ctrl-header">
          <span class="ctrl-label">Kenaikan sewa / tahun</span>
          <span class="ctrl-value" id="v-naik">5%</span>
        </div>
        <input type="range" id="s-naik" min="0" max="10" step="1" value="5" oninput="update()">
        <div class="slider-minmax"><span>0%</span><span>10%</span></div>
      </div>

      <div class="control-group">
        <div class="ctrl-header">
          <span class="ctrl-label">Pendapatan bisnis / bulan</span>
          <span class="ctrl-value" id="v-rev">Rp 9,9 jt</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <input type="range" id="s-rev" min="1" max="900000000" step="1" value="9900000" oninput="syncRevFromSlider()" style="flex:1;margin-bottom:0">
          <input type="number" id="n-rev" min="1" max="900000000" value="9900000" oninput="syncRevFromInput()" style="width:88px;font-family:var(--font-mono);font-size:13px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 8px;outline:none;-moz-appearance:textfield">
        </div>
        <div class="slider-minmax"><span>1</span><span>900 jt</span></div>
      </div>

      <div class="control-group">
        <div class="ctrl-header">
          <span class="ctrl-label">IPL / m² / bulan</span>
          <span class="ctrl-value" id="v-ipl">Rp 5.000</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <input type="range" id="s-ipl" min="0" max="50000" step="1" value="5000" oninput="syncIplFromSlider()" style="flex:1;margin-bottom:0">
          <input type="number" id="n-ipl" min="0" max="50000" value="5000" oninput="syncIplFromInput()" style="width:72px;font-family:var(--font-mono);font-size:13px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 8px;outline:none;-moz-appearance:textfield">
        </div>
        <div class="slider-minmax"><span>0</span><span>50.000/m²</span></div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">Iuran Pengelolaan Lingkungan — biaya bulanan di luar sewa</div>
      </div>

      <div class="divider"></div>

      <div class="panel-title">Preset lokasi</div>
      <div class="quick-presets">
        <button class="preset-btn" onclick="applyPreset(500,6667,5,9900000)">Pinggiran BDG</button>
        <button class="preset-btn" onclick="applyPreset(700,12500,6,15000000)">Kolektor</button>
        <button class="preset-btn" onclick="applyPreset(600,20833,7,25000000)">Jl. Utama</button>
        <button class="preset-btn" onclick="applyPreset(1000,33333,8,40000000)">Pusat Kota</button>
      </div>

      <div class="divider"></div>

      <div class="panel-title">Kelayakan th-1</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:6px">Beban sewa vs pendapatan</div>
      <div style="font-family:var(--font-mono);font-size:22px;font-weight:500" id="ratio-val">—</div>
      <div class="progress-track"><div class="progress-fill" id="ratio-bar" style="width:0%;background:var(--green)"></div></div>
      <div style="font-size:11px;color:var(--muted);margin-top:6px" id="ratio-label">—</div>
    </div>

    <!-- RIGHT: Results -->
    <div class="results">

      <!-- Metrics row -->
      <div class="metrics-row">
        <div class="metric-card accent-card">
          <div class="mc-label">Sewa tahun ke-1</div>
          <div class="mc-value" id="m-sewa1">—</div>
          <div class="mc-sub" id="m-sewa1-sub">—</div>
        </div>
        <div class="metric-card">
          <div class="mc-label">IPL / bulan (total lahan)</div>
          <div class="mc-value" id="m-ipl">—</div>
          <div class="mc-sub" id="m-ipl-sub">—</div>
        </div>
        <div class="metric-card">
          <div class="mc-label">Total beban 10 tahun</div>
          <div class="mc-value" id="m-total">—</div>
          <div class="mc-sub" id="m-total-sub">—</div>
        </div>
        <div class="metric-card">
          <div class="mc-label">Sewa tahun ke-10</div>
          <div class="mc-value" id="m-sewa10">—</div>
          <div class="mc-sub">setelah eskalasi</div>
        </div>
        <div class="metric-card" style="grid-column:span 2; border:1px solid rgba(200,240,74,0.25); background:linear-gradient(135deg,#14171c 60%,rgba(200,240,74,0.04))">
          <div class="mc-label">Total sewa 10 tahun</div>
          <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap">
            <div class="mc-value" id="m-totalsewa" style="font-size:28px;color:#c8f04a">—</div>
            <div style="font-size:12px;color:#7a7870;font-family:var(--font-mono)" id="m-totalsewa-full">—</div>
          </div>
          <div style="display:flex;gap:20px;margin-top:8px;flex-wrap:wrap" id="m-totalsewa-breakdown"></div>
        </div>
        <div class="metric-card" style="grid-column:span 2">
          <div class="mc-label">Ekuivalen bulan kerja (sewa + IPL)</div>
          <div class="mc-value" id="m-bep">—</div>
          <div class="mc-sub">dari pendapatan bisnis</div>
        </div>
      </div>

      <!-- Charts -->
      <div class="section-card">
        <div class="sc-header">
          <span class="sc-title">Akumulasi biaya sewa vs pendapatan (10 tahun)</span>
          <div style="display:flex;gap:12px;font-size:11px;color:var(--muted);align-items:center">
